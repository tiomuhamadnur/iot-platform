APP_NAME=IoT Platform
APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=UTC

# Public hostnames
APP_HOST=127.0.0.1
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:3001
WEBSOCKET_URL=http://127.0.0.1:3000

# Public ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
API_PORT=8000
FRONTEND_PORT=3001
WEBSOCKET_PORT=3000
POSTGRES_PORT=5432
INFLUXDB_PORT=8086
REDIS_PORT=6379
MQTT_PORT=1883
MQTT_WS_PORT=8083
MQTT_WSS_PORT=8084
MQTT_TLS_PORT=8883
EMQX_DASHBOARD_PORT=18083

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=iot
DB_USERNAME=admin
DB_PASSWORD=secret

# InfluxDB
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-me
INFLUXDB_ORG=iot
INFLUXDB_BUCKET=telemetry

# MQTT
MQTT_HOST=emqx
MQTT_USERNAME=admin
MQTT_PASSWORD=public

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=

# Frontend runtime
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1
NEXT_PUBLIC_WS_URL=http://127.0.0.1:3000

# License
LICENSE_SERVER_URL=https://your-domain.com
LICENSE_KEY=
